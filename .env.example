# BioAxis root environment example
#
# This file is an inventory of required configuration keys. It is safe to commit
# because it contains placeholders only. Do not paste real project URLs, tokens,
# service-role keys, JWT secrets, passwords, or personal data here.
#
# Runtime files:
# - Backend reads backend/.env through docker-compose and pydantic settings.
# - Frontend reads frontend/.env.local through docker-compose and Next.js.
# - Copy only the relevant keys into each runtime file.

# Backend: Supabase server-side access.
# Required by backend/app/main.py at process startup.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Backend: async database URL for SQLAlchemy-based modules.
# Use a local development database URL in backend/.env when needed.
DATABASE_URL=
SQL_ECHO=false

# Backend: Gemini integration.
# Required only for AI/NLP extraction paths.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=8
GEMINI_MAX_RETRIES=2

# Frontend: browser-safe Supabase values.
# These are public client values, not service-role credentials.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Frontend: backend API origin used by browser-side nutrition views.
NEXT_PUBLIC_PYTHON_API_URL=http://localhost:8000

# Frontend: server-side chat route key, if that route is enabled locally.
# Prefer using the backend Gemini variables for backend-owned AI paths.
GOOGLE_GENERATIVE_AI_API_KEY=
