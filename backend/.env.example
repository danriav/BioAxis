# Async PostgreSQL URL (Supabase: Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/healthtech
SQL_ECHO=false

# Supabase API (Project Settings → API)
# Project URL → use as SUPABASE_URL (e.g. https://xxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co
# anon public → use as SUPABASE_ANON_KEY (safe for client apps with RLS; never commit real keys)
SUPABASE_ANON_KEY=your-anon-key-here
